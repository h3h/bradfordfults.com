<!DOCTYPE html>
<% lang = defined?(@resource) && @resource.respond_to?(:lang) && @resource.lang.present? ? @resource.lang : "en" %>
<html lang="<%= lang %>">
  <head>
    <%= meta_tags %>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Roboto+Slab:wght@600;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400;1,8..60,600&display=swap" rel="stylesheet">

    <% if defined?(@resource) && @resource.respond_to?(:salutation) && @resource.salutation %>
      <link href="https://fonts.googleapis.com/css2?family=Rancho&display=swap" rel="stylesheet" type="text/css">
    <% end %>

    <%= stylesheet_link_tag :app %>

    <link rel="alternate" type="application/rss+xml" title="<%= Perron.configuration.site_name %>" href="/feed.xml">

    <% if defined?(@resource) && @resource.respond_to?(:translated_post) && @resource.translated_post.present? %>
      <% other = @resource.translated_post %>
      <link rel="alternate" title="<%= other.display_title %>" href="/posts/<%= other.slug %>" hreflang="<%= other.lang %>">
    <% elsif defined?(@resource) && @resource.respond_to?(:translated_page) && @resource.translated_page.present? %>
      <% other = @resource.translated_page %>
      <link rel="alternate" title="<%= other.title %>" href="/<%= other.slug %>" hreflang="<%= other.lang %>">
    <% end %>

    <link rel="apple-touch-icon" sizes="57x57" href="/img/favicon/apple-icon-57x57.png">
    <link rel="apple-touch-icon" sizes="60x60" href="/img/favicon/apple-icon-60x60.png">
    <link rel="apple-touch-icon" sizes="72x72" href="/img/favicon/apple-icon-72x72.png">
    <link rel="apple-touch-icon" sizes="76x76" href="/img/favicon/apple-icon-76x76.png">
    <link rel="apple-touch-icon" sizes="114x114" href="/img/favicon/apple-icon-114x114.png">
    <link rel="apple-touch-icon" sizes="120x120" href="/img/favicon/apple-icon-120x120.png">
    <link rel="apple-touch-icon" sizes="144x144" href="/img/favicon/apple-icon-144x144.png">
    <link rel="apple-touch-icon" sizes="152x152" href="/img/favicon/apple-icon-152x152.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-icon-180x180.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/img/favicon/android-icon-192x192.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/img/favicon/favicon-96x96.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon/favicon-16x16.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png">

    <script type="module" src="/script/SpicySections.js"></script>
  </head>
  <body<% if defined?(@resource) && @resource.respond_to?(:body_class) && @resource.body_class.present? %> class="<%= @resource.body_class %>"<% end %>>
    <%= render "shared/header", lang: lang %>

    <section class="main-content">
      <%= yield %>
      <% unless request.path == "/" || request.path == "/hogar" || request.path == "/hogar/" %>
        <%= render "shared/nav", lang: lang %>
      <% end %>
    </section>

    <%= render "shared/footer", lang: lang %>
  </body>
</html>
