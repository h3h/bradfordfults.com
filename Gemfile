# Use the Puma web server [https://github.com/puma/puma]
gem "puma", ">= 5.0"

# Lovely static site generation
gem 'perron', '~> 0.16.0'

# Markdown support
gem "kramdown"
gem "kramdown-parser-gfm"

# SCSS support
gem "dartsass-rails"
