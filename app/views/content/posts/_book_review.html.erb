<article class="post content book-review" itemprop="mainEntity" itemscope itemtype="https://schema.org/Book">
  <div class="post-content" itemprop="review" itemscope itemtype="https://schema.org/Review">
    <header class="post-header">
      <h1 class="post-title" itemprop="name headline"><%= post.book_name %></h1>
      <p class="book-author">by <span itemprop="author"><%= post.book_author %></span></p>
      <p class="book-rating">
        <%= render "shared/book_stars", rating: post.book_rating %>
        <span class="book-rating-number" itemprop="reviewRating"><%= post.book_rating %></span>
      </p>
      <p class="book-spoilers">
        <% if post.book_spoilers %>
          (<strong>WARNING:</strong> Spoilers ahead!)
        <% else %>
          (No spoilers in this review.)
        <% end %>
      </p>
    </header>
    <div class="book-review-body" itemprop="reviewBody">
      <%= markdownify post.content %>
    </div>
  </div>
  <div class="post-meta">
    <% if post.category.present? %>
      <p>
        <a href="/<%= post.category %>"><%= post.category.capitalize %></a>
      </p>
    <% end %>
    <p>Bradford Fults</p>
    <p>
      <time datetime="<%= post.published_at.iso8601 %>" itemprop="datePublished"><%= post.published_at.strftime("%B %-d, %Y") %></time>
    </p>
  </div>
</article>
